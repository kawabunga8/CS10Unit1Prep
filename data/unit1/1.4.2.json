{
  "id": "1.4.2",
  "title": "Properties Galore!",
  "description": "Properties: border, borderWidth, lineWidth (lines), dashes, rotateAngle, opacity, roundness (stars), plus label properties.",
  "flashcards": [
    {
      "term": "border + borderWidth",
      "definition": "Adds an outline around a shape. border is the color; borderWidth is the thickness (number > 0).",
      "example": "Rect(100, 150, 200, 100, fill='dodgerBlue', border='black', borderWidth=2)"
    },
    {
      "term": "lineWidth (lines only)",
      "definition": "Lines do not use border. Use lineWidth to make a line thicker/thinner.",
      "example": "Line(50, 50, 350, 50, lineWidth=6)"
    },
    {
      "term": "dashes",
      "definition": "Makes a line or a border dashed. dashes is True or False.",
      "example": "Line(50, 100, 350, 100, dashes=True)"
    },
    {
      "term": "rotateAngle",
      "definition": "Rotates a shape clockwise by a number of degrees.",
      "example": "Rect(200, 200, 120, 60, rotateAngle=45)"
    },
    {
      "term": "opacity",
      "definition": "0–100. 100 is solid; 0 is invisible.",
      "example": "Circle(200, 200, 30, fill='dodgerBlue', opacity=80)"
    },
    {
      "term": "roundness (stars only)",
      "definition": "0–100. Makes star points more rounded.",
      "example": "Star(200, 200, 30, 5, roundness=80)"
    },
    {
      "term": "Label properties",
      "definition": "Labels can use: size (>0), bold (True/False), italic (True/False), font (one of the provided fonts).",
      "example": "Label('Title', 200, 30, size=32, bold=True, italic=False, font='cinzel')"
    }
  ],
